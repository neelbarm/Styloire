# Canonical URL for metadata, sitemap, and Open Graph (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://styloire.co

# Set to "true" only while wiring data — hides the small “Data” strip in production by default
# NEXT_PUBLIC_SHOW_DATA_SOURCE=true

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Encryption key for connected account secrets (must decode to 32 bytes).
# Generate with: openssl rand -base64 32
STYLOIRE_ENCRYPTION_KEY=replace-with-32-byte-base64-or-64-char-hex

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PRICE_ID=price_xxx

# Google OAuth (Gmail API)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=https://your-app.com/api/email/callback/google

# Microsoft OAuth (Outlook / Graph)
MICROSOFT_CLIENT_ID=xxx
MICROSOFT_CLIENT_SECRET=xxx
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://your-app.com/api/email/callback/microsoft

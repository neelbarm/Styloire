# Canonical URL for metadata, sitemap, and Open Graph (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://styloire.co

# Set to "true" only while wiring data — hides the small “Data” strip in production by default
# NEXT_PUBLIC_SHOW_DATA_SOURCE=true

# Supabase (optional — when unset, dashboard + request detail use bundled mock data)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Defaults to the UUID seeded in supabase/migrations/20260417120000_styloire_v1_schema.sql
# STYLOIRE_DASHBOARD_USER_ID=a0000000-0000-4000-8000-000000000001
